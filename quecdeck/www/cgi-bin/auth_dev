#!/bin/bash
# Developer session unlock endpoint.
#
# Requires an active admin session (enforced by auth.lua before this script
# runs). Checks the provided password against /opt/etc/.htpasswd_dev using
# the fixed "devadmin" username.
#
# GET: returns {"unlocked": true/false} for the current session.
# POST: validates password; on success sets the dev-unlock flag and returns
#        {"unlocked": true}.
#
# Brute-force protection: 5 failed attempts trigger a 15-minute lockout,
# tracked per client IP under /tmp/quecdeck/dev_auth_failures (mirroring
# auth_login). Per-session tracking would let an attacker who already holds
# admin reset the counter by simply logging in again, since each login mints a
# fresh session file.

. /usrdata/quecdeck/script/cgi-lib.sh

# Most responses here are a single small JSON line (with header).
_json() { cgi_output_json; printf '%s\n' "$1"; }

# Extract session token from Cookie header.
token=$(printf '%s' "${HTTP_COOKIE:-}" | tr ';' '\n' | sed 's/^ *//' | \
    grep '^session=' | head -1 | cut -d= -f2)

# Validate token format before using in a file path (defense in depth;
# auth.lua enforces the same constraint before this script runs).
if ! printf '%s' "$token" | grep -qE '^[A-Za-z0-9]{1,128}$'; then
    _json '{"unlocked":false}'
    exit 0
fi

SESSION_FILE="/tmp/quecdeck/sessions/${token}"
# The dev-unlock flag lives in a sibling "<token>.dev" file rather than inside
# the session file. auth.lua rewrites the session file on every request (to
# refresh last_access); keeping dev_unlocked in a separate file that only this
# script writes prevents that frequent rewrite from clobbering the flag, with no
# shared lock needed (auth.lua would have to fork to take one).
DEV_FILE="${SESSION_FILE}.dev"

if [ ! -f "$SESSION_FILE" ]; then
    _json '{"unlocked":false}'
    exit 0
fi

dev_unlocked=$(grep '^dev_unlocked=' "$DEV_FILE" 2>/dev/null | cut -d= -f2)

# GET: return current unlock status and whether a dev password has been configured.
if [ "$REQUEST_METHOD" = "GET" ]; then
    configured="false"
    [ -s /opt/etc/.htpasswd_dev ] && configured="true"
    [ "$dev_unlocked" = "1" ] && unlocked="true" || unlocked="false"
    _json "$(printf '{"unlocked":%s,"configured":%s}' "$unlocked" "$configured")"
    exit 0
fi

# POST: attempt to unlock.
cgi_require_post
cgi_read_post
password=$(get_post_param "password")

if [ -z "$password" ] || [ "${#password}" -gt 256 ]; then
    _json '{"unlocked":false,"error":"invalid"}'
    exit 0
fi

now=$(date +%s)
ACCESS_LOG="/tmp/quecdeck/logs/access_events.jsonl"
client_ip=$(cgi_client_ip)
wan_ip=$(cgi_wan_ip)

# Brute-force protection per client IP (rationale in the header comment).
FAILURE_DIR="/tmp/quecdeck/dev_auth_failures"

# Reject immediately if locked out.
if bf_locked "$FAILURE_DIR" "$client_ip"; then
    log_access_event "$ACCESS_LOG" "{\"ts\":$now,\"type\":\"dev_unlock_locked\",\"ip\":\"$client_ip\",\"wan_ip\":\"$wan_ip\"}"
    _json '{"unlocked":false,"error":"locked"}'
    exit 0
fi

if validate_password dev devadmin "$password"; then
    # Success: clear failures, mark dev-unlocked (own file, temp+rename, no lock).
    bf_clear "$FAILURE_DIR" "$client_ip"
    (umask 077; printf 'dev_unlocked=1\n' > "${DEV_FILE}.tmp.$$") && mv "${DEV_FILE}.tmp.$$" "$DEV_FILE"
    log_access_event "$ACCESS_LOG" "{\"ts\":$now,\"type\":\"dev_unlock_success\",\"ip\":\"$client_ip\",\"wan_ip\":\"$wan_ip\"}"
    _json '{"unlocked":true}'
else
    if [ "$(bf_fail "$FAILURE_DIR" "$client_ip")" = "locked" ]; then
        log_access_event "$ACCESS_LOG" "{\"ts\":$now,\"type\":\"dev_unlock_locked\",\"ip\":\"$client_ip\",\"wan_ip\":\"$wan_ip\"}"
        _json '{"unlocked":false,"error":"locked"}'
    else
        log_access_event "$ACCESS_LOG" "{\"ts\":$now,\"type\":\"dev_unlock_failure\",\"ip\":\"$client_ip\",\"wan_ip\":\"$wan_ip\"}"
        _json '{"unlocked":false,"error":"wrong"}'
    fi
fi
