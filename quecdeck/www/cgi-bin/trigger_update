#!/bin/bash

. /usrdata/quecdeck/www/cgi-bin/cgi-lib.sh
cgi_require_post
cgi_read_post
cgi_output_json

tag=$(get_post_param tag)

if ! echo "$tag" | grep -qE '^v[0-9]+\.[0-9]+\.[0-9]+$'; then
    printf '{"ok":false,"error":"Invalid version tag"}\n'
    exit 0
fi

UPDATE_LOCK_FILE=/tmp/quecdeck_update.lock
if ! command -v flock >/dev/null 2>&1; then
    printf '{"ok":false,"error":"Internal error: flock unavailable"}\n'
    exit 0
fi
if ! ( umask 0; exec 9>"$UPDATE_LOCK_FILE"; flock -n 9 ); then
    printf '{"ok":false,"error":"An update is already in progress"}\n'
    exit 0
fi

/opt/bin/sudo /usrdata/quecdeck/script/run_update.sh "$tag" >/dev/null
if [ $? -ne 0 ]; then
    printf '{"ok":false,"error":"Failed to start update process"}\n'
    exit 0
fi

printf '{"ok":true,"tag":"%s"}\n' "$tag"
