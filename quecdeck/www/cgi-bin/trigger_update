#!/bin/bash

. /usrdata/quecdeck/script/cgi-lib.sh
cgi_require_post
cgi_read_post
cgi_output_json

tag=$(get_post_param tag)

if ! echo "$tag" | grep -qE '^v[0-9]+\.[0-9]+\.[0-9]+$'; then
    printf '{"ok":false,"error":"Invalid version tag"}\n'
    exit 0
fi

# Mutual exclusion is handled by systemd in the root-run scripts (the install
# runs as the install_quecdeck oneshot). This CGI just relays run_update.sh's
# result: exit code 2 means an update is already in progress.
/opt/bin/sudo /usrdata/quecdeck/script/run_update.sh "$tag" >/dev/null
rc=$?
if [ "$rc" -eq 2 ]; then
    printf '{"ok":false,"error":"An update is already in progress"}\n'
    exit 0
elif [ "$rc" -ne 0 ]; then
    printf '{"ok":false,"error":"Failed to start update process"}\n'
    exit 0
fi

printf '{"ok":true,"tag":"%s"}\n' "$tag"
