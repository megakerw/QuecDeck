#!/bin/bash

. /usrdata/quecdeck/script/cgi-lib.sh
cgi_require_post
cgi_read_post
cgi_output_json

tag=$(get_post_param tag)

if ! echo "$tag" | grep -qE '^v[0-9]+\.[0-9]+\.[0-9]+$'; then
    printf '{"ok":false,"error":"Invalid version tag"}\n'
    exit 0
fi

# The update lock is handled entirely by the root-run scripts. This CGI must not
# create or open it: under SELinux (SEAndroid) a lock created by this www-data
# process gets a type the root updater cannot write, wedging every future update.
# run_update.sh does the authoritative flock check (which auto-releases if a
# previous update died) and reports "already in progress" via exit code 2.
/opt/bin/sudo /usrdata/quecdeck/script/run_update.sh "$tag" >/dev/null
rc=$?
if [ "$rc" -eq 2 ]; then
    printf '{"ok":false,"error":"An update is already in progress"}\n'
    exit 0
elif [ "$rc" -ne 0 ]; then
    printf '{"ok":false,"error":"Failed to start update process"}\n'
    exit 0
fi

printf '{"ok":true,"tag":"%s"}\n' "$tag"
