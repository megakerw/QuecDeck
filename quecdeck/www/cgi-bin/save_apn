#!/bin/bash

. /usrdata/quecdeck/script/cgi-lib.sh
cgi_require_post
cgi_read_post

apn=$(get_post_param apn)
ip_type=$(get_post_param ip_type)
sim=$(get_post_param sim)
roam_pref=$(get_post_param roam_pref)
mbn=$(get_post_param mbn)
action=$(get_post_param action)

cgi_output_text

# Validate each provided param
if [ -n "$apn" ] && ! printf '%s' "$apn" | grep -qE '^[a-zA-Z0-9._-]{1,100}$'; then
    cgi_error "ERROR: invalid APN"
fi

if [ -n "$ip_type" ] && ! printf '%s' "$ip_type" | grep -qE '^(IP|IPV6|IPV4V6)$'; then
    cgi_error "ERROR: invalid ip_type"
fi

# apn and ip_type must be provided together
if { [ -n "$apn" ] && [ -z "$ip_type" ]; } || { [ -z "$apn" ] && [ -n "$ip_type" ]; }; then
    cgi_error "ERROR: apn and ip_type must both be provided"
fi

if [ -n "$sim" ] && ! printf '%s' "$sim" | grep -qE '^[12]$'; then
    cgi_error "ERROR: invalid sim slot"
fi

if [ -n "$roam_pref" ] && ! printf '%s' "$roam_pref" | grep -qE '^[0-9]$'; then
    cgi_error "ERROR: invalid roam_pref"
fi

if [ -n "$mbn" ] && ! printf '%s' "$mbn" | grep -qE '^[01]$'; then
    cgi_error "ERROR: invalid mbn"
fi

# Build AT command from validated parts
at_parts=""
append_at() {
    [ -z "$at_parts" ] && at_parts="$1" || at_parts="${at_parts};${1}"
}

[ -n "$apn" ]       && append_at "+CGDCONT=1,\"${ip_type}\",\"${apn}\""
[ -n "$sim" ]       && append_at "+QUIMSLOT=${sim}"
[ -n "$roam_pref" ] && append_at "+QNWPREFCFG=\"roam_pref\",${roam_pref}"
[ -n "$mbn" ]       && append_at "+QMBNCFG=\"AutoSel\",${mbn}"

if [ -z "$at_parts" ]; then
    cgi_error "ERROR: no parameters provided"
fi

result=$(atcmd_run "AT${at_parts}")
at_result "$result"
cache_invalidate "$_CACHE_MODEM_ALL" "$_CACHE_NETWORK" "$_CACHE_MODEM_CONN"

# Only reconnect/reboot if the setting actually applied. A failed AT command
# must not trigger a disruptive modem reset.
if at_response_ok "$result" && [ "$action" = "reconnect" ]; then
    (
        sleep 2
        wc_running=0
        /bin/systemctl is-active watchcat >/dev/null 2>&1 && wc_running=1
        [ "$wc_running" = "1" ] && /opt/bin/sudo /bin/systemctl stop watchcat
        atcmd_run 'AT+CFUN=0'
        sleep 10
        atcmd_run 'AT+CFUN=1'
        sleep 20
        [ "$wc_running" = "1" ] && /opt/bin/sudo /bin/systemctl start watchcat
    ) >/dev/null 2>&1 &
    disown $!
elif at_response_ok "$result" && [ "$action" != "simswap" ]; then
    ( sleep 5; atcmd_fire 'AT+CFUN=1,1' 10000 ) >/dev/null 2>&1 &
    disown $!
fi
