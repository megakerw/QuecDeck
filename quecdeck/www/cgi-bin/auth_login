#!/bin/bash

. /usrdata/quecdeck/script/cgi-lib.sh

# Only accept POST. Redirect GET requests (e.g. iOS Safari BFCache restoring this URL) to home.
# auth.lua will then forward valid sessions through or redirect to login if the session is expired.
if [ "$REQUEST_METHOD" != "POST" ]; then
    printf 'Status: 303 See Other\r\nLocation: /\r\nContent-Type: text/plain\r\nContent-Length: 0\r\n\r\n'
    exit 0
fi

cgi_check_cors
cgi_read_post

username=$(get_post_param "username")
password=$(get_post_param "password")

ACCESS_LOG="/tmp/quecdeck/logs/access_events.jsonl"
json_error() { printf 'Status: 200 OK\r\nContent-Type: application/json\r\nCache-Control: no-store\r\n\r\n{"ok":false,"error":"%s"}' "$1"; }

# Brute-force protection: 5 attempts, then 15-minute lockout per IP
FAILURE_DIR="/tmp/quecdeck/auth_failures"
mkdir -p "$FAILURE_DIR" && chmod 700 "$FAILURE_DIR"

# Opportunistic cleanup: remove failure records older than 1 day (~1% of requests).
# Lockouts last 15 minutes, so any record older than a day is guaranteed expired.
[ $(( RANDOM % 100 )) -eq 0 ] && find "$FAILURE_DIR" -maxdepth 1 -type f -mtime +1 -delete 2>/dev/null
MAX_ATTEMPTS=5
LOCKOUT_SECS=900

client_ip=$(printf '%s' "${REMOTE_ADDR:-unknown}" | tr -cd 'A-Fa-f0-9.:')
[ -z "$client_ip" ] && client_ip="unknown"
failure_file="$FAILURE_DIR/${client_ip//:/_}"
wan_ip=$(/sbin/ip route show dev bridge0 2>/dev/null | awk '/scope link/{print $1; exit}')
[ -z "$wan_ip" ] && wan_ip=""

now=$(date +%s)

# Validate username and password before any lockout check or logging.
# Ensures $username is safe to embed in JSON log strings.
if ! printf '%s' "$username" | grep -qE '^[a-zA-Z0-9_-]{1,64}$'; then
    json_error "invalid"; exit 0
fi

if [ -z "$password" ] || [ "${#password}" -gt 256 ]; then
    json_error "invalid"; exit 0
fi

# Reject immediately if locked out
if [ -f "$failure_file" ]; then
    lockout_until=$(grep '^lockout_until=' "$failure_file" | cut -d= -f2)
    if [ -n "$lockout_until" ] && [ "$lockout_until" -gt "$now" ]; then
        log_access_event "$ACCESS_LOG" "{\"ts\":$now,\"type\":\"login_locked\",\"user\":\"$username\",\"ip\":\"$client_ip\",\"wan_ip\":\"$wan_ip\"}"
        json_error "locked"; exit 0
    fi
fi

# Check credentials against admin htpasswd
role=""
if validate_htpasswd "/opt/etc/.htpasswd" "$username" "$password"; then
    role="admin"
fi

if [ -z "$role" ]; then
    sleep 1    # per-attempt delay

    # Increment failure count
    count=0
    if [ -f "$failure_file" ]; then
        count=$(grep '^count=' "$failure_file" | cut -d= -f2)
    fi
    count=$(( ${count:-0} + 1 ))

    if [ "$count" -ge "$MAX_ATTEMPTS" ]; then
        lockout_until=$(( now + LOCKOUT_SECS ))
        printf 'count=0\nlockout_until=%s\n' "$lockout_until" > "$failure_file"
        log_access_event "$ACCESS_LOG" "{\"ts\":$now,\"type\":\"login_locked\",\"user\":\"$username\",\"ip\":\"$client_ip\",\"wan_ip\":\"$wan_ip\"}"
        json_error "locked"
    else
        printf 'count=%s\nlockout_until=0\n' "$count" > "$failure_file"
        log_access_event "$ACCESS_LOG" "{\"ts\":$now,\"type\":\"login_failure\",\"user\":\"$username\",\"ip\":\"$client_ip\",\"wan_ip\":\"$wan_ip\"}"
        json_error "invalid"
    fi
    exit 0
fi

# Successful login: clear failure record
rm -f "$failure_file"

# Create session. Directory must be 700 so other local users cannot list tokens.
# Use umask to set permissions atomically on creation rather than a separate chmod.
(umask 077; mkdir -p /tmp/quecdeck/sessions)
token=$(tr -dc 'A-Za-z0-9' < /dev/urandom | head -c 64)
now=$(date +%s)
log_access_event "$ACCESS_LOG" "{\"ts\":$now,\"type\":\"login_success\",\"user\":\"$username\",\"ip\":\"$client_ip\",\"wan_ip\":\"$wan_ip\"}"

(umask 077; printf 'user=%s\nrole=%s\ncreated=%s\nlast_access=%s\n' \
    "$username" "$role" "$now" "$now" > "/tmp/quecdeck/sessions/$token")

printf 'Status: 200 OK\r\n'
printf 'Content-Type: application/json\r\n'
printf 'Set-Cookie: session=%s; Path=/; HttpOnly; Secure; SameSite=Strict\r\n' "$token"
printf 'Cache-Control: no-store\r\n'
printf '\r\n'
printf '{"ok":true}'
