#!/bin/bash

# Ping multiple hosts — return OK if any one responds
# Targets: Google DNS, Cloudflare DNS, Quad9 DNS

echo "Content-type: text/plain"
echo ""

for host in 8.8.8.8 1.1.1.1 9.9.9.9; do
    if ping -c 1 -W 1 "$host" 2>/dev/null | grep -q "0% packet loss"; then
        echo "OK"
        exit 0
    fi
done

echo "ERROR"
