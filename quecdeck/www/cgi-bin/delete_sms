#!/bin/bash

. /usrdata/quecdeck/script/cgi-lib.sh
cgi_require_post
cgi_read_post

action=$(get_post_param action)
indices=$(get_post_param indices)

cgi_output_text

if [ "$action" = "all" ]; then
    # Delete-all emits no output until the final OK (no streamed lines to keep
    # the per-line gap timer alive), so 3s acts as a total timeout; a full
    # inbox can take longer to erase.
    atcmd_run 'AT+CMGD=,4' 10000
elif [ -n "$indices" ]; then
    # Validate: comma-separated positive integers only
    if ! printf '%s' "$indices" | grep -qE '^[0-9]+(,[0-9]+)*$'; then
        cgi_error "ERROR: indices must be comma-separated integers"
    fi
    # Build semicolon-joined delete command
    at_cmd=$(echo "$indices" | awk -F',' '
    {
        out = "AT+CMGD=" $1
        for (i = 2; i <= NF; i++) out = out ";+CMGD=" $i
        print out
    }')
    atcmd_run "$at_cmd" 10000
else
    cgi_error "ERROR: provide action=all or indices=N,N,..."
fi
