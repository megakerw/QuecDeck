#!/bin/bash

. /usrdata/quecdeck/script/cgi-lib.sh
cgi_check_cors
cgi_output_json

LOG=/tmp/install_quecdeck.log
STATUS_FILE=/tmp/quecdeck_update.status
UPDATE_LOCK_FILE=/tmp/quecdeck_update.lock

# True (lock acquired) means nothing is holding it, i.e. no update is running.
_update_is_idle() {
    command -v flock >/dev/null 2>&1 || return 1
    ( umask 0; exec 9>"$UPDATE_LOCK_FILE"; flock -n 9 )
}

offset=$(printf '%s' "${QUERY_STRING:-}" | tr '&' '\n' | grep '^offset=' | cut -d= -f2)
case "$offset" in
    ''|*[!0-9]*) offset=0 ;;
esac

if [ ! -f "$STATUS_FILE" ]; then
    printf '{"log":"","offset":0,"status":"idle"}\n'
    exit 0
fi

ack=$(printf '%s' "${QUERY_STRING:-}" | tr '&' '\n' | grep '^ack=' | cut -d= -f2)
if [ "$ack" = "1" ]; then
    raw_status=$(cat "$STATUS_FILE" 2>/dev/null)
    case "$raw_status" in
        done|failed|failed:rollback_ok|failed:rollback_failed)
            rm -f "$STATUS_FILE"
            ;;
        *)
            _update_is_idle && rm -f "$STATUS_FILE"
            ;;
    esac
    printf '{"ok":true}\n'
    exit 0
fi

if [ -f "$LOG" ]; then
    total=$(wc -c < "$LOG" | tr -d ' ')
    [ "$offset" -gt "$total" ] && offset=0
    chunk_b64=$(tail -c "+$((offset + 1))" "$LOG" | tr -d '\033' | sed 's/\[[0-9;]*m//g' | base64 | tr -d '\n')
else
    total=0
    chunk_b64=""
fi

raw_status=$(cat "$STATUS_FILE" 2>/dev/null)
case "$raw_status" in
    done)                   status="done"   ; rollback="none"   ;;
    failed:rollback_ok)     status="failed" ; rollback="ok"     ;;
    failed:rollback_failed) status="failed" ; rollback="failed" ;;
    failed)                 status="failed" ; rollback="none"   ;;
    *)
        status="running" ; rollback="none"
        _update_is_idle && status="failed"
        ;;
esac

printf '{"log":"%s","offset":%s,"status":"%s","rollback":"%s"}\n' "$chunk_b64" "$total" "$status" "$rollback"
