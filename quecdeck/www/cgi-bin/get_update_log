#!/bin/bash

. /usrdata/quecdeck/script/cgi-lib.sh
cgi_check_cors
cgi_output_json

LOG=/tmp/install_quecdeck.log
STATUS_FILE=/tmp/quecdeck_update.status
UPDATE_PID_FILE=/tmp/quecdeck_update.pid

# True (idle) means no live update process. The update runs as root and the lock
# it holds cannot be opened from this www-data CGI under SELinux (SEAndroid), so
# liveness uses the updater's published PID, with a short grace on the status
# file for the brief window before that PID exists (e.g. during download) so a
# running update is never misread as dead.
_update_is_idle() {
    local pid
    pid=$(cat "$UPDATE_PID_FILE" 2>/dev/null)
    case "$pid" in
        ''|*[!0-9]*)
            # No PID yet: treat a freshly-written status as alive (covers the
            # download window before the inner publishes its PID).
            [ -n "$(find "$STATUS_FILE" -mmin -5 2>/dev/null)" ] && return 1
            return 0
            ;;
    esac
    # PID published: authoritative, prompt liveness via /proc.
    [ -d "/proc/$pid" ] && return 1 || return 0
}

offset=$(printf '%s' "${QUERY_STRING:-}" | tr '&' '\n' | grep '^offset=' | cut -d= -f2)
case "$offset" in
    ''|*[!0-9]*) offset=0 ;;
esac

if [ ! -f "$STATUS_FILE" ]; then
    printf '{"log":"","offset":0,"status":"idle"}\n'
    exit 0
fi

ack=$(printf '%s' "${QUERY_STRING:-}" | tr '&' '\n' | grep '^ack=' | cut -d= -f2)
if [ "$ack" = "1" ]; then
    raw_status=$(cat "$STATUS_FILE" 2>/dev/null)
    case "$raw_status" in
        done|failed|failed:rollback_ok|failed:rollback_failed)
            rm -f "$STATUS_FILE"
            ;;
        *)
            _update_is_idle && rm -f "$STATUS_FILE"
            ;;
    esac
    printf '{"ok":true}\n'
    exit 0
fi

if [ -f "$LOG" ]; then
    total=$(wc -c < "$LOG" | tr -d ' ')
    [ "$offset" -gt "$total" ] && offset=0
    chunk_b64=$(tail -c "+$((offset + 1))" "$LOG" | tr -d '\033' | sed 's/\[[0-9;]*m//g' | base64 | tr -d '\n')
else
    total=0
    chunk_b64=""
fi

raw_status=$(cat "$STATUS_FILE" 2>/dev/null)
case "$raw_status" in
    done)                   status="done"   ; rollback="none"   ;;
    failed:rollback_ok)     status="failed" ; rollback="ok"     ;;
    failed:rollback_failed) status="failed" ; rollback="failed" ;;
    failed)                 status="failed" ; rollback="none"   ;;
    *)
        status="running" ; rollback="none"
        _update_is_idle && status="failed"
        ;;
esac

printf '{"log":"%s","offset":%s,"status":"%s","rollback":"%s"}\n' "$chunk_b64" "$total" "$status" "$rollback"
