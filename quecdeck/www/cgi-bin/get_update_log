#!/bin/bash

. /usrdata/quecdeck/script/cgi-lib.sh
cgi_check_cors
cgi_output_json

LOG=/tmp/install_quecdeck.log
STATUS_FILE=/tmp/quecdeck_update.status

offset=$(printf '%s' "${QUERY_STRING:-}" | tr '&' '\n' | grep '^offset=' | cut -d= -f2)
case "$offset" in
    ''|*[!0-9]*) offset=0 ;;
esac

if [ ! -f "$STATUS_FILE" ]; then
    printf '{"log":"","offset":0,"status":"idle"}\n'
    exit 0
fi

ack=$(printf '%s' "${QUERY_STRING:-}" | tr '&' '\n' | grep '^ack=' | cut -d= -f2)
if [ "$ack" = "1" ]; then
    # The status file is root-owned in sticky /tmp, so www-data cannot unlink it
    # here; run_update.sh clears it (terminal states only) as root via sudo.
    /opt/bin/sudo /usrdata/quecdeck/script/run_update.sh --clear-status >/dev/null 2>&1
    printf '{"ok":true}\n'
    exit 0
fi

if [ -f "$LOG" ]; then
    total=$(wc -c < "$LOG" | tr -d ' ')
    [ "$offset" -gt "$total" ] && offset=0
    chunk_b64=$(tail -c "+$((offset + 1))" "$LOG" | tr -d '\033' | sed 's/\[[0-9;]*m//g' | base64 | tr -d '\n')
else
    total=0
    chunk_b64=""
fi

raw_status=$(cat "$STATUS_FILE" 2>/dev/null)
case "$raw_status" in
    done)                   status="done"   ; rollback="none"   ;;
    failed:rollback_ok)     status="failed" ; rollback="ok"     ;;
    failed:rollback_failed) status="failed" ; rollback="failed" ;;
    failed)                 status="failed" ; rollback="none"   ;;
    *)
        # Non-terminal status ("running" or empty). Distinguish a live install
        # from a crash via systemd: the install runs as the install_quecdeck
        # oneshot. "failed" = it crashed before writing an outcome (a SIGKILL
        # bypasses the cleanup trap); anything else (activating, or the brief
        # installer-download window before the service starts) is still running.
        # An empty/failed query defaults to running, never a false "failed".
        if [ "$(systemctl is-active install_quecdeck 2>/dev/null)" = "failed" ]; then
            status="failed" ; rollback="none"
        else
            status="running" ; rollback="none"
        fi
        ;;
esac

printf '{"log":"%s","offset":%s,"status":"%s","rollback":"%s"}\n' "$chunk_b64" "$total" "$status" "$rollback"
