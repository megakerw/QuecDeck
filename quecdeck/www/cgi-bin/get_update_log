#!/bin/bash

. /usrdata/quecdeck/www/cgi-bin/cgi-lib.sh
cgi_check_cors
cgi_output_json

LOG=/tmp/install_quecdeck.log
PID_FILE=/tmp/quecdeck_update.pid

offset=$(printf '%s' "${QUERY_STRING:-}" | tr '&' '\n' | grep '^offset=' | cut -d= -f2)
case "$offset" in
    ''|*[!0-9]*) offset=0 ;;
esac

if [ ! -f "$LOG" ]; then
    printf '{"log":"","offset":0,"status":"idle"}\n'
    exit 0
fi

total=$(wc -c < "$LOG" | tr -d ' ')
[ "$offset" -gt "$total" ] && offset=0

chunk_b64=$(tail -c "+$((offset + 1))" "$LOG" | tr -d '\033' | sed 's/\[[0-9;]*m//g' | base64 | tr -d '\n')

if grep -q "Install Summary" "$LOG" 2>/dev/null; then
    # The installer always prints the summary and exits 0, even when a
    # critical step failed (it just records FAILED in that row) — so the
    # marker alone doesn't mean success. Check the rows that actually gate
    # whether QuecDeck ended up usable.
    if grep -qE '(Lighttpd|QuecDeck)[^A-Za-z].*FAILED' "$LOG" 2>/dev/null; then
        status="failed"
    else
        status="done"
    fi
elif grep -q "===UPDATE_FAILED===" "$LOG" 2>/dev/null; then
    status="failed"
elif [ -f "$PID_FILE" ] && ! kill -0 "$(cat "$PID_FILE" 2>/dev/null)" 2>/dev/null; then
    status="failed"
elif [ -z "$(find "$LOG" -mmin -5 2>/dev/null)" ]; then
    # Log hasn't been written to in over 5 minutes with no terminal marker —
    # the process stalled or was killed without cleaning up.
    status="failed"
else
    status="running"
fi

# On failure, report whether a rollback was attempted and whether it succeeded,
# so the UI can tell the user whether their previous install was restored.
rollback="none"
if [ "$status" = "failed" ]; then
    if grep -q "Rolling back to previous installation" "$LOG" 2>/dev/null; then
        if grep -q "Rollback complete. Previous version restored." "$LOG" 2>/dev/null; then
            rollback="ok"
        else
            rollback="failed"
        fi
    fi
fi

printf '{"log":"%s","offset":%s,"status":"%s","rollback":"%s"}\n' "$chunk_b64" "$total" "$status" "$rollback"

if [ "$status" = "done" ] || [ "$status" = "failed" ]; then
    rm -f "$LOG" "$PID_FILE"
fi
