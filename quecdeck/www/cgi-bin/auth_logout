#!/bin/bash

# Extract session token from Cookie header
cookie="${HTTP_COOKIE:-}"
token=$(printf '%s' "$cookie" | sed 's/.*[^A-Za-z0-9]session=\([A-Za-z0-9]*\).*/\1/;s/^session=\([A-Za-z0-9]*\).*/\1/')

# Delete session file (validate token format to prevent path traversal)
if printf '%s' "$token" | grep -qE '^[A-Za-z0-9]{1,128}$'; then
    session_file="/tmp/quecdeck/sessions/$token"
    if [ -f "$session_file" ]; then
        logout_user=$(grep '^user=' "$session_file" | cut -d= -f2)
        client_ip=$(printf '%s' "${REMOTE_ADDR:-unknown}" | tr -cd 'A-Fa-f0-9.:')
        [ -z "$client_ip" ] && client_ip="unknown"
        wan_ip=$(/sbin/ip route show dev bridge0 2>/dev/null | awk '/scope link/{print $1; exit}')
        [ -z "$wan_ip" ] && wan_ip=""
        printf '{"ts":%s,"type":"logout","user":"%s","ip":"%s","wan_ip":"%s"}\n' \
            "$(date +%s)" "$logout_user" "$client_ip" "$wan_ip" \
            >> /tmp/quecdeck/logs/access_events.jsonl
    fi
    rm -f "$session_file"
fi

# Expire the cookie and redirect to login
printf 'Status: 303 See Other\r\n'
printf 'Location: /login.html\r\n'
printf 'Set-Cookie: session=deleted; Path=/; HttpOnly; Secure; SameSite=Strict; Max-Age=0; Expires=Thu, 01 Jan 1970 00:00:00 GMT\r\n'
printf 'Cache-Control: no-store\r\n'
printf 'Content-Type: text/plain\r\n'
printf 'Content-Length: 0\r\n'
printf '\r\n'
