#!/usr/bin/env bash
# Pre-commit hook: regenerates quecdeck/checksums.sha256 whenever any
# of the listed files are staged for commit.
#
# One-time setup (from repo root):
#   git config core.hooksPath .githooks

CHECKSUMS_FILE="quecdeck/checksums.sha256"

CHECKSUMMED_FILES=(
  update_quecdeck.sh
  quecdeck/script/create_watchcat.sh
  quecdeck/script/remove_watchcat.sh
  quecdeck/script/watchcat.sh
  quecdeck/script/json-lib.sh
  quecdeck/script/cgi-lib.sh
  quecdeck/script/at-lib.sh
  quecdeck/script/create_scheduled_restart.sh
  quecdeck/script/remove_scheduled_restart.sh
  quecdeck/script/scheduled_restart.sh
  quecdeck/script/connection_logger.sh
  quecdeck/script/lighttpd_prestart.sh
  quecdeck/script/lean_mode.sh
  quecdeck/script/write_htpasswd.sh
  quecdeck/script/firewall.sh
  quecdeck/systemd/firewall.service
  quecdeck/systemd/lean-mode.service
  quecdeck/systemd/lighttpd.service
  quecdeck/systemd/watchcat.service
  quecdeck/systemd/ttyd.service
  quecdeck/systemd/scheduled_restart.service
  quecdeck/systemd/atcmd-daemon.service
  quecdeck/systemd/connection-logger.service
  quecdeck/console/ttyd.bash
  quecdeck/quecdeckdevpasswd
  quecdeck/auth.lua
  quecdeck/console/menu/start_menu.sh
  quecdeck/www/index.html
  quecdeck/www/network.html
  quecdeck/www/settings.html
  quecdeck/www/monitoring.html
  quecdeck/www/logs.html
  quecdeck/www/deviceinfo.html
  quecdeck/www/scanner.html
  quecdeck/www/sms.html
  quecdeck/www/developer.html
  quecdeck/www/js/utils.js
  quecdeck/www/js/dark-mode.js
  quecdeck/www/js/parse-settings.js
  quecdeck/www/js/populate-bands.js
  quecdeck/www/js/login.js
  quecdeck/www/js/home.js
  quecdeck/www/js/settings.js
  quecdeck/www/js/scanner.js
  quecdeck/www/js/network-names.js
  quecdeck/www/js/deviceinfo.js
  quecdeck/www/js/developer.js
  quecdeck/www/js/sms.js
  quecdeck/www/js/watchcat.js
  quecdeck/www/js/network.js
  quecdeck/www/js/logs.js
  quecdeck/www/js/setup.js
  quecdeck/www/js/nav.js
  quecdeck/www/js/update.js
  quecdeck/www/css/styles.css
  quecdeck/www/cgi-bin/auth_login
  quecdeck/www/cgi-bin/auth_logout
  quecdeck/www/cgi-bin/auth_dev
  quecdeck/www/cgi-bin/get_deviceinfo
  quecdeck/www/cgi-bin/get_settings
  quecdeck/www/cgi-bin/set_setting
  quecdeck/www/cgi-bin/get_network_info
  quecdeck/www/cgi-bin/set_bands
  quecdeck/www/cgi-bin/save_apn
  quecdeck/www/cgi-bin/save_network_pref
  quecdeck/www/cgi-bin/set_cell_lock
  quecdeck/www/cgi-bin/get_neighbour_cells
  quecdeck/www/cgi-bin/get_sms
  quecdeck/www/cgi-bin/delete_sms
  quecdeck/www/cgi-bin/user_atcommand
  quecdeck/www/cgi-bin/get_ping
  quecdeck/www/cgi-bin/get_dashboard
  quecdeck/www/cgi-bin/get_watchcat_status
  quecdeck/www/cgi-bin/get_watchcat_stats
  quecdeck/www/cgi-bin/watchcat_maker
  quecdeck/www/cgi-bin/get_scheduled_restart
  quecdeck/www/cgi-bin/scheduled_restart_maker
  quecdeck/www/cgi-bin/toggle_ttyd
  quecdeck/www/cgi-bin/get_set_lanip
  quecdeck/www/cgi-bin/get_ippt_status
  quecdeck/www/cgi-bin/get_upnp_status
  quecdeck/www/cgi-bin/run_cell_scan
  quecdeck/www/cgi-bin/get_service_status
  quecdeck/www/cgi-bin/get_scan_status
  quecdeck/www/cgi-bin/get_logs
  quecdeck/www/cgi-bin/get_restart_log
  quecdeck/www/cgi-bin/clear_restart_log
  quecdeck/www/cgi-bin/check_update
  quecdeck/www/cgi-bin/trigger_update
  quecdeck/www/cgi-bin/get_update_log
  quecdeck/www/cgi-bin/init_setup
  quecdeck/console/.profile
  quecdeck/bin/atcli
  quecdeck/lighttpd.conf
  quecdeck/script/run_update.sh
  quecdeck/www/update.html
  quecdeck/www/login.html
  quecdeck/www/setup.html
  quecdeck/www/favicon.ico
  quecdeck/www/js/alpinejs.min.js
  quecdeck/www/js/bootstrap.bundle.min.js
  quecdeck/www/css/bootstrap.min.css
  quecdeck/www/fonts/poppins-v23-latin-300italic.woff2
  quecdeck/www/fonts/poppins-v23-latin-300.woff2
  quecdeck/www/fonts/poppins-v23-latin-500italic.woff2
  quecdeck/www/fonts/poppins-v23-latin-500.woff2
  quecdeck/www/fonts/poppins-v23-latin-600italic.woff2
  quecdeck/www/fonts/poppins-v23-latin-600.woff2
  quecdeck/www/fonts/poppins-v23-latin-700italic.woff2
  quecdeck/www/fonts/poppins-v23-latin-700.woff2
  quecdeck/www/fonts/poppins-v23-latin-italic.woff2
  quecdeck/www/fonts/poppins-v23-latin-regular.woff2
)

# Check whether any checksummed file is staged
staged=$(git diff --cached --name-only)
needs_update=0
for f in "${CHECKSUMMED_FILES[@]}"; do
  if echo "$staged" | grep -qx "$f"; then
    needs_update=1
    break
  fi
done

if [ "$needs_update" = "0" ]; then
  exit 0
fi

# Every checksummed file must exist in the index. A listed-but-never-added
# file ships a release without it that still passes verification (no
# checksum line, and the updater's wget failure is silent).
index_missing=0
for f in "${CHECKSUMMED_FILES[@]}"; do
  if ! git show ":$f" > /dev/null 2>&1; then
    echo "ERROR: $f is in CHECKSUMMED_FILES but not in the git index."
    index_missing=1
  fi
done
if [ "$index_missing" = "1" ]; then
  echo ""
  echo "Commit blocked: git add the file(s) above, or remove them from CHECKSUMMED_FILES."
  exit 1
fi

# Update ?v= cache-busting query string in HTML files.
# Version is an 8-char hash of all staged JS+CSS content; changes whenever
# any JS or CSS file changes, causing browsers to discard the 1-year cache.
asset_version=$(
  for f in "${CHECKSUMMED_FILES[@]}"; do
    case "$f" in *.js|*.css) git show ":$f" 2>/dev/null ;; esac
  done | sha256sum | cut -c1-8
)
HTML_FILES=(
  quecdeck/www/index.html
  quecdeck/www/login.html
  quecdeck/www/setup.html
  quecdeck/www/network.html
  quecdeck/www/settings.html
  quecdeck/www/monitoring.html
  quecdeck/www/logs.html
  quecdeck/www/update.html
  quecdeck/www/scanner.html
  quecdeck/www/sms.html
  quecdeck/www/deviceinfo.html
  quecdeck/www/developer.html
)
for html in "${HTML_FILES[@]}"; do
  git show ":$html" > /dev/null 2>&1 || continue
  blob=$(git show ":$html" | \
    sed 's/\(\.\(js\|css\)\)\(?v=[a-f0-9]*\)\?"/\1?v='"$asset_version"'"/g' | \
    git hash-object -w --stdin)
  git update-index --cacheinfo "100644,$blob,$html"
done

# Regenerate: hash the staged (index) content so checksums are always LF,
# matching what GitHub serves to the device regardless of core.autocrlf.
{
  echo "# SHA256 checksums for QuecDeck files"
  echo "# Auto-generated by .githooks/pre-commit; do not edit manually"
  echo "# NOTE: protects against partial repo tampering; a full repo compromise"
  echo "# would require updating this file too."
  echo ""
  for f in "${CHECKSUMMED_FILES[@]}"; do
    git show ":$f" > /dev/null 2>&1 || continue
    hash=$(git show ":$f" | sha256sum | awk '{print $1}')
    echo "$hash *$f"
  done
} > "$CHECKSUMS_FILE"

git add "$CHECKSUMS_FILE"
echo "Updated $CHECKSUMS_FILE"

# Verify that hardcoded hashes in quecdeck.sh match staged file content.
# These hashes are the trust anchor for bootstrap-critical scripts;
# they must be updated in quecdeck.sh whenever the corresponding file changes.
PINNED_FILES=(
  installentware.sh
  update_quecdeck.sh
  optional/sshd/sshd.service
  optional/sshd/update_sshd_ip.sh
  quecdeck/quecdeckpasswd
  quecdeck/quecdeckdevpasswd
  quecdeck/script/lean_mode.sh
  quecdeck/systemd/lean-mode.service
)

# Read quecdeck.sh from the index if staged, else from the working tree
if git diff --cached --name-only | grep -qx "quecdeck.sh"; then
  quecdeck_sh=$(git show ":quecdeck.sh")
else
  quecdeck_sh=$(cat quecdeck.sh)
fi

hash_errors=0
for f in "${PINNED_FILES[@]}"; do
  # Only check files that exist in the index
  git show ":$f" > /dev/null 2>&1 || continue

  actual=$(git show ":$f" | sha256sum | awk '{print $1}')
  expected=$(echo "$quecdeck_sh" | grep -o "[a-f0-9]\{64\}.*$(basename "$f")" | awk '{print $1}' | head -1)

  if [ -z "$expected" ]; then
    continue  # file not pinned in quecdeck.sh yet
  fi

  if [ "$actual" != "$expected" ]; then
    echo ""
    echo "ERROR: Hash mismatch for $f"
    echo "  Expected (quecdeck.sh): $expected"
    echo "  Actual:                 $actual"
    echo "  Update the hash in quecdeck.sh to: $actual"
    hash_errors=1
  fi
done

if [ "$hash_errors" = "1" ]; then
  echo ""
  echo "Commit blocked: update the hardcoded hashes in quecdeck.sh and re-stage it."
  exit 1
fi

# Enforce the AT access layer: runtime code (CGIs, scripts, console) must send
# AT commands through at-lib.sh (atcmd_run/atcmd_fire), never invoke the atcli
# binary directly. Scoped to those dirs so the daemon-launch unit, docs, and
# dev tools aren't swept in; at-lib.sh is the gateway itself. The pattern
# catches the path (any /atcli), the symlink, and the $_ATCLI variable, but
# not the $_ATCLI_SOCK socket or the atcli.sock path. Keep scope + pattern in
# sync with the atcli guard in tools/ci-checks.sh.
ATCLI_INVOKE_RE='(/atcli|\$[{]?_ATCLI[}]?)([^A-Za-z0-9._/-]|$)'
atcli_errors=0
while IFS= read -r f; do
  case "$f" in
    quecdeck/script/at-lib.sh) continue ;;
    quecdeck/www/cgi-bin/*|quecdeck/script/*|quecdeck/console/*) ;;
    *) continue ;;
  esac
  if git show ":$f" 2>/dev/null | grep -qE "$ATCLI_INVOKE_RE"; then
    echo ""
    echo "ERROR: $f invokes atcli directly."
    echo "  Source /usrdata/quecdeck/script/at-lib.sh and use atcmd_run"
    echo "  (or atcmd_fire for fire-and-forget reboots) instead."
    atcli_errors=1
  fi
done < <(git diff --cached --name-only)

if [ "$atcli_errors" = "1" ]; then
  echo ""
  echo "Commit blocked: route AT commands through at-lib.sh."
  exit 1
fi

# Dialect guard: bash-only code must never execute under sh. Two rules:
# (1) any script sourcing cgi-lib.sh/at-lib.sh (bash-dialect) must declare
#     #!/bin/bash;
# (2) systemd Exec* lines override shebangs, so a unit's /bin/sh|/bin/bash
#     must match the shebang of the script it launches.
# Checked against the index so results reflect what is being committed.
dialect_errors=0

for f in $(git ls-files 'quecdeck/script/*.sh' 'quecdeck/www/cgi-bin/*' 'quecdeck/console/*'); do
  content=$(git show ":$f" 2>/dev/null) || continue
  echo "$content" | grep -qE '^[[:space:]]*\.[[:space:]]+/usrdata/quecdeck/script/(cgi-lib|at-lib)\.sh' || continue
  first=$(echo "$content" | head -1)
  if [ "$first" != "#!/bin/bash" ]; then
    echo ""
    echo "ERROR: $f sources cgi-lib/at-lib (bash-dialect) but starts with '$first'."
    echo "  Change the shebang to #!/bin/bash."
    dialect_errors=1
  fi
done

for u in $(git ls-files 'quecdeck/systemd/*.service'); do
  while IFS= read -r line; do
    interp=$(echo "$line" | sed -nE 's,^Exec[A-Za-z]+=(/bin/(sh|bash)) /usrdata/quecdeck/.*,\1,p')
    script=$(echo "$line" | sed -nE 's,^Exec[A-Za-z]+=/bin/(sh|bash) (/usrdata/quecdeck/[^ ]+).*,\2,p')
    [ -z "$interp" ] || [ -z "$script" ] && continue
    repo_path="quecdeck${script#/usrdata/quecdeck}"
    shebang=$(git show ":$repo_path" 2>/dev/null | head -1)
    [ -z "$shebang" ] && continue
    if [ "$shebang" != "#!$interp" ]; then
      echo ""
      echo "ERROR: $u launches $script with $interp but its shebang is '$shebang'."
      echo "  The Exec line overrides the shebang; make them match."
      dialect_errors=1
    fi
  done < <(git show ":$u" 2>/dev/null | grep -E '^Exec[A-Za-z]+=')
done

if [ "$dialect_errors" = "1" ]; then
  echo ""
  echo "Commit blocked: shell dialect mismatch (see errors above)."
  exit 1
fi

# Dev-gate guard: every CGI the developer page calls must be dev-gated in
# auth.lua, so a new dev endpoint can't silently ship admin-gated only.
# auth_dev is the unlock endpoint itself and stays admin-level.
devgate_errors=0
gated_eps=$(git show :quecdeck/auth.lua 2>/dev/null \
  | sed -n '/requires_dev_unlocked = /,/^if /p' | grep -oE '/cgi-bin/[a-z_]+')
while IFS= read -r ep; do
  [ -z "$ep" ] && continue
  [ "$ep" = "/cgi-bin/auth_dev" ] && continue
  if ! echo "$gated_eps" | grep -qx "$ep"; then
    echo ""
    echo "ERROR: $ep is called by the developer page but not dev-gated in auth.lua."
    echo "  Add it to requires_dev_unlocked in auth.lua."
    devgate_errors=1
  fi
done < <({ git show :quecdeck/www/js/developer.js; git show :quecdeck/www/developer.html; } 2>/dev/null \
  | grep -oE '/cgi-bin/[a-z_]+' | sort -u)

if [ "$devgate_errors" = "1" ]; then
  echo ""
  echo "Commit blocked: dev-gate the new endpoint in auth.lua."
  exit 1
fi

# Host-side test suite (pure shell functions + JS structure). Runs against
# the working tree; the fast set skips tests that sleep.
if ! bash tools/run-tests.sh > /tmp/quecdeck_test_output 2>&1; then
  cat /tmp/quecdeck_test_output
  echo ""
  echo "Commit blocked: test suite failed (tools/run-tests.sh)."
  rm -f /tmp/quecdeck_test_output
  exit 1
fi
rm -f /tmp/quecdeck_test_output
