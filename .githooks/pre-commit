# Check whether any checksummed file is staged
staged=$(git diff --cached --name-only)
needs_update=0
for f in "${CHECKSUMMED_FILES[@]}"; do
  if echo "$staged" | grep -qx "$f"; then
    needs_update=1
    break
  fi
done

if [ "$needs_update" = "0" ]; then
  exit 0
fi

# Update ?v= cache-busting query string in HTML files.
# Version is an 8-char hash of all staged JS+CSS content — changes whenever
# any JS or CSS file changes, causing browsers to discard the 1-year cache.
asset_version=$(
  for f in "${CHECKSUMMED_FILES[@]}"; do
    case "$f" in *.js|*.css) git show ":$f" 2>/dev/null ;; esac
  done | sha256sum | cut -c1-8
)
HTML_FILES=(
  quecdeck/www/index.html
  quecdeck/www/login.html
  quecdeck/www/setup.html
  quecdeck/www/network.html
  quecdeck/www/settings.html
  quecdeck/www/monitoring.html
  quecdeck/www/logs.html
  quecdeck/www/scanner.html
  quecdeck/www/sms.html
  quecdeck/www/deviceinfo.html
  quecdeck/www/developer.html
)
for html in "${HTML_FILES[@]}"; do
  git show ":$html" > /dev/null 2>&1 || continue
  blob=$(git show ":$html" | \
    sed 's/\(\.\(js\|css\)\)\(?v=[a-f0-9]*\)\?"/\1?v='"$asset_version"'"/g' | \
    git hash-object -w --stdin)
  git update-index --cacheinfo "100644,$blob,$html"
done

# Regenerate — hash the staged (index) content so checksums are always LF,
# matching what GitHub serves to the device regardless of core.autocrlf.
{
  echo "# SHA256 checksums for QuecDeck files"
  echo "# Auto-generated by .githooks/pre-commit — do not edit manually"
  echo "# NOTE: protects against partial repo tampering; a full repo compromise"
  echo "# would require updating this file too."
  echo ""
  for f in "${CHECKSUMMED_FILES[@]}"; do
    git show ":$f" > /dev/null 2>&1 || continue
    hash=$(git show ":$f" | sha256sum | awk '{print $1}')
    echo "$hash *$f"
  done
} > "$CHECKSUMS_FILE"

git add "$CHECKSUMS_FILE"
echo "Updated $CHECKSUMS_FILE"
